.DS_Store
Thumbs.db
Desktop.ini

# =========================
# 📡 Addressables / Streaming
# =========================
**/Assets/AddressableAssetsData/*/*.bin*
**/Assets/StreamingAssets/aa.meta
**/Assets/StreamingAssets/*/aa/*

# =========================
# 🔐 Private / Crash Files
# =========================
*.private
*.private.meta
^*.private.[0-9]+$
^*.private.[0-9]+.meta$
sysinfo.txt
crashlytics-build.properties

